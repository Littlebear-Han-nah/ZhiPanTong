<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AR资产识别 - 智盘通</title>
    <script src="https://aframe.io/releases/1.4.2/aframe.min.js"></script>
    <script src="https://raw.githack.com/AR-js-org/AR.js/master/aframe/build/aframe-ar-nft.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Microsoft YaHei', sans-serif; color: #333; background: #000; }
        .container { width: 100%; height: 100vh; position: relative; }
        .header { position: absolute; top: 20px; left: 0; right: 0; text-align: center; z-index: 100; }
        .header h2 { color: white; font-size: 24px; text-shadow: 0 0 10px rgba(0,0,0,0.5); }
        .back-btn { position: absolute; top: 20px; left: 20px; z-index: 100; }
        .back-btn a { color: white; text-decoration: none; background: rgba(0,0,0,0.5); padding: 10px 20px; border-radius: 4px; }
        #ar-container { width: 100%; height: 100%; }
        .control-panel { position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%); background: rgba(255,255,255,0.9); padding: 15px 20px; border-radius: 8px; box-shadow: 0 2px 15px rgba(0,0,0,0.3); z-index: 100; display: flex; gap: 20px; align-items: center; }
        .control-panel p { color: #333; font-size: 14px; }
        .control-btn { padding: 8px 16px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; }
        .control-btn:hover { background: #0056b3; }
        .asset-info { position: absolute; top: 80px; left: 20px; background: rgba(255,255,255,0.9); padding: 15px; border-radius: 8px; box-shadow: 0 2px 15px rgba(0,0,0,0.3); z-index: 100; width: 300px; display: none; }
        .asset-info h3 { color: #007bff; margin-bottom: 10px; }
        .asset-info p { margin-bottom: 5px; font-size: 14px; }
        .close-btn { position: absolute; top: 10px; right: 10px; background: none; border: none; cursor: pointer; color: #666; font-size: 18px; }
        .close-btn:hover { color: #dc3545; }
    </style>
</head>
<body>
    <div class="container">
        <div class="back-btn">
            <a href="/assets">← 返回资产列表</a>
        </div>
        <div class="header">
            <h2>AR资产识别（请允许摄像头权限）</h2>
        </div>
        <a-scene arjs="trackingMethod: best; sourceType: webcam; detectionMode: mono; maxDetectionRate: 60;" id="ar-container">

            <a-entity camera></a-entity>
            <a-entity id="asset-marker" visible="false">
                <a-box position="0 0 0" width="0.5" height="0.5" depth="0.5" color="#007bff" opacity="0.5"></a-box>
                <a-text id="asset-text" value="加载中..." align="center" color="#007bff" font-size="30" position="0 0.3 0"></a-text>
            </a-entity>
        </a-scene>
        <div class="asset-info" id="assetInfoPanel">
            <button class="close-btn" onclick="closeInfoPanel()">×</button>
            <h3 id="assetName">资产名称</h3>
            <p><strong>资产ID：</strong><span id="assetId"></span></p>
            <p><strong>状态：</strong><span id="assetStatus"></span></p>
            <p><strong>位置：</strong><span id="assetLocation"></span></p>
            <p><strong>利用率：</strong><span id="assetUtil"></span></p>
            <p><strong>建议：</strong><span id="assetSuggestion"></span></p>
            <a id="assetDetailLink" href="#" class="control-btn" style="display: inline-block; margin-top: 10px;">查看详情</a>
        </div>
        <div class="control-panel">
            <p>操作：对准资产/RFID标签自动识别 | 点击手动扫描</p>
            <button class="control-btn" onclick="manualScan()">手动输入RFID</button>
            <button class="control-btn" onclick="refreshCamera()">刷新摄像头</button>
        </div>
    </div>
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const targetRFID = urlParams.get('rfid');
        
        document.addEventListener('DOMContentLoaded', function() {
            const marker = document.getElementById('asset-marker');
            const infoPanel = document.getElementById('assetInfoPanel');
            
            if (targetRFID) {
                setTimeout(() => recognizeAsset(targetRFID), 2000);
            }
            
            function recognizeAsset(rfid) {
                fetch('/ar/recognize', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ rfid: rfid })
                }).then(res => res.json()).then(data => {
                    if (data.status === 'success') {
                        const asset = data.asset;
                        marker.querySelector('#asset-text').setAttribute('value', 
                            `${asset.name}\n状态：${asset.status}\n利用率：${asset.utilization_rate}`);
                        marker.setAttribute('visible', 'true');
                        marker.object3D.position.set(0, 0, -1);
                        
                        document.getElementById('assetName').textContent = asset.name;
                        document.getElementById('assetId').textContent = asset.id;
                        document.getElementById('assetStatus').textContent = asset.status;
                        document.getElementById('assetLocation').textContent = asset.location;
                        document.getElementById('assetUtil').textContent = asset.utilization_rate;
                        document.getElementById('assetSuggestion').textContent = asset.suggestion;
                        document.getElementById('assetDetailLink').href = `/assets/${asset.id}`;
                        infoPanel.style.display = 'block';
                    } else {
                        alert(data.msg);
                        marker.setAttribute('visible', 'false');
                        infoPanel.style.display = 'none';
                    }
                }).catch(err => alert('识别失败，请重试'));
            }
            
            const testRFIDs = ['RFID001', 'RFID002', 'RFID003', 'RFID004', 'RFID005'];
            let scanInterval = setInterval(() => {
                if (!targetRFID) recognizeAsset(testRFIDs[Math.floor(Math.random() * testRFIDs.length)]);
            }, 8000);
            
            window.manualScan = function() {
                const rfid = prompt('请输入RFID标签号：', 'RFID001');
                if (rfid) {
                    clearInterval(scanInterval);
                    recognizeAsset(rfid);
                    scanInterval = setInterval(() => recognizeAsset(testRFIDs[Math.floor(Math.random() * testRFIDs.length)]), 8000);
                }
            };
            
            window.refreshCamera = function() { location.reload(); };
            window.closeInfoPanel = function() { infoPanel.style.display = 'none'; };
        });
    </script>
</body>
</html>
